      "task_id": "weather_room_scene",
      "task_title": "Weather and Room Scene",
      "task_type": "spoken_output",
      "required_scenarios": [
        "04_home_daily_tasks",
        "05_weather_environment"
      ],
      "learning_goal": "Combine weather state and location phrase to establish a simple scene.",
      "templates": [
        {
          "template_id": "weather_room_scene_t1",
          "text": "It is {weather_state_chunk}. I am in the {room_chunk}.",
          "slots": [
            "weather_state_chunk",
            "room_chunk"
          ]
        },
        {
          "template_id": "weather_room_scene_t2",
          "text": "How is the weather? It is {weather_state_chunk}. I am in the {room_chunk}.",
          "slots": [
            "weather_state_chunk",
            "room_chunk"
          ]
        }
      ],
      "slot_sources": {
        "weather_state_chunk": {
          "from": "data/sentence_registry/A1/05_weather_environment.json",
          "semantic_groups": [
            "weather_state"
          ]
        },
        "room_chunk": {
          "type": "controlled_list",
          "items": [
            "kitchen",
            "living room",
            "dining room",
            "garden",
            "bedroom"
          ]
        }
      },
      "sample_outputs": [
        {
          "text": "It is sunny today. I am in the garden.",
          "slots_used": {
            "weather_state_chunk": "sunny today",
            "room_chunk": "garden"
          }
        },
        {
          "text": "How is the weather? It is cold and windy. I am in the living room.",
          "slots_used": {
            "weather_state_chunk": "cold and windy",
            "room_chunk": "living room"
          }
        }
      ],
      "drill_modes": [
        "spoken_output",
        "weather_prompt",
        "scene_setting"
      ],
      "pass_condition": "Student can combine a weather sentence with a room/location sentence without changing the be-verb pattern.",
      "generator_rules": {
        "safe_for_generation": true,
        "use_controlled_slots": true,
        "blocked_outputs": [
          "It is kitchen.",
          "I am in the sunny.",
          "I am in garden."
        ],
        "notes": "Use weather_state_chunk for weather and room_chunk for locations. Keep 'in the' in the template."
      }
    },

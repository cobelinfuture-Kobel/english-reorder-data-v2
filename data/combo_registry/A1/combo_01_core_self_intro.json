  "combo_tasks": [
    {
      "task_id": "self_intro_basic",
      "task_title": "Basic Self Introduction",
      "task_type": "spoken_output",
      "required_scenarios": [
        "01_personal_info",
        "03_health_body"
      ],
      "learning_goal": "Combine personal age, role identity, feeling, and physical feature into a short self-introduction.",
      "templates": [
        {
          "template_id": "self_intro_basic_t1",
          "text": "Hello! I am {age_chunk}. I am {role_chunk}. I am {feeling_adjective}.",
          "slots": [
            "age_chunk",
            "role_chunk",
            "feeling_adjective"
          ]
        },
        {
          "template_id": "self_intro_basic_t2",
          "text": "Hi! I am {role_chunk}. I am {age_chunk}. I have got {physical_feature_chunk}.",
          "slots": [
            "role_chunk",
            "age_chunk",
            "physical_feature_chunk"
          ]
        }
      ],
      "slot_sources": {
        "age_chunk": {
          "from": "data/sentence_registry/A1/01_personal_info.json",
          "semantic_groups": [
            "age"
          ]
        },
        "role_chunk": {
          "from": "data/sentence_registry/A1/01_personal_info.json",
          "semantic_groups": [
            "role_identity"
          ]
        },
        "feeling_adjective": {
          "from": "data/sentence_registry/A1/01_personal_info.json",
          "semantic_groups": [
            "feeling"
          ]
        },
        "physical_feature_chunk": {
          "from": "data/sentence_registry/A1/03_health_body.json",
          "semantic_groups": [
            "physical_feature"
          ]
        }
      },
      "sample_outputs": [
        {
          "text": "Hello! I am seven years old. I am a student. I am happy.",
          "slots_used": {
            "age_chunk": "seven years old",
            "role_chunk": "a student",
            "feeling_adjective": "happy"
          }
        },
        {
          "text": "Hi! I am a student. I am seven years old. I have got brown eyes.",
          "slots_used": {
            "role_chunk": "a student",
            "age_chunk": "seven years old",
            "physical_feature_chunk": "brown eyes"
          }
        }
      ],
      "drill_modes": [
        "spoken_output",
        "rapid_substitution",
        "exit_ticket"
      ],
      "pass_condition": "Student can produce a three-sentence self-introduction using controlled chunks with no be-verb or have-got errors.",
      "generator_rules": {
        "safe_for_generation": true,
        "use_controlled_slots": true,
        "blocked_outputs": [
          "I am student.",
          "I have got headache.",
          "I am seven."
        ],
        "notes": "Use phrase chunks such as 'a student' and 'seven years old'. Do not generate from raw words."
      }
    },
